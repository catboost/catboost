cc_library(
    name = "json_fast_sax",
    srcs = [
        "parser.cpp",  # generated from parser.rl6 by Ragel
        "unescape.cpp",
    ],
    hdrs = glob(["*.h"]),
    deps = [
        "//library/cpp/json/common:json_common",
        "//util",
    ],
    visibility = ["//visibility:public"],
)
