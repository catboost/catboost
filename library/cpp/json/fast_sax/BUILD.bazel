# Note: parser.rl6 must be compiled with Ragel to produce parser.cpp.
# If parser.cpp is not pre-generated, install Ragel and uncomment the
# genrule below.
#
# genrule(
#     name = "fast_sax_parser_gen",
#     srcs = ["parser.rl6"],
#     outs = ["parser.cpp"],
#     cmd = "ragel -CG2 -o $@ $(SRCS)",
